{
  "name": "projeto-escolar-prisma",
  "version": "1.0.0",
  "description": "Projeto prático de banco de dados com MySQL e Prisma (JavaScript)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node src/index.js",
    "init": "npx prisma init",
    "generate": "npx prisma generate",
    "migrate": "npx prisma migrate dev",
    "studio": "npx prisma studio",
    "seed": "node prisma/seed.js",
    "reset": "npx prisma migrate reset",
    "rollback": "npx prisma migrate resolve --rolled-back"
  },
  "keywords": ["prisma", "mysql", "javascript"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.18.0"
  },
  "devDependencies": {
    "prisma": "^5.18.0"
  }
}
